---
import TechBadge from './TechBadge.astro';

interface Props {
  title: string;
  description: string;
  image?: string;
  technologies: string[];
  slug: string;
  featured?: boolean;
  devPeriod?: string;
  type?: string;
}

const { title, description, image, technologies, slug, featured, devPeriod, type } = Astro.props;

// 이미지가 없거나 placeholder 면 default 이미지 사용
const defaultImage = '/images/defult.jpeg';
const hasRealImage = image && image !== '/images/placeholder.svg' && image !== defaultImage;
const displayImage = hasRealImage ? image : defaultImage;
---

<a href={`/projects/${slug}`} class="project-card" data-featured={featured} data-type={type}>
  <div class="card-image">
    <img src={displayImage} alt={title} loading="lazy" />
  </div>
  <div class="card-content">
    <h3>{title}</h3>
    <p class="description">{description}</p>
    {devPeriod && (
      <p class="dev-period">📅 {devPeriod}</p>
    )}
    <div class="tech-stack">
      {technologies.map((tech) => <TechBadge name={tech} />)}
    </div>
  </div>
</a>

<style>
  .project-card {
    display: block;
    background: linear-gradient(145deg, rgba(70, 72, 75, 0.6) 0%, rgba(55, 57, 60, 0.7) 100%);
    border: 1px solid rgba(120, 123, 126, 0.3);
    border-top: 1px solid rgba(140, 143, 146, 0.4);
    border-left: 1px solid rgba(140, 143, 146, 0.4);
    border-radius: 10px;
    overflow: hidden;
    transition: transform 0.2s, box-shadow 0.2s, border-color 0.2s;
    backdrop-filter: blur(10px);
  }

  .project-card:hover {
    transform: translateY(-5px);
    box-shadow: 
      0 8px 32px rgba(0, 0, 0, 0.3),
      0 0 40px rgba(255, 255, 255, 0.05);
    border-color: rgba(160, 163, 166, 0.5);
    text-decoration: none;
  }

  .project-card[data-featured="true"] {
    border-color: var(--primary);
  }

  .card-image {
    width: 100%;
    height: 200px;
    overflow: hidden;
    background: var(--border);
  }

  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .card-content {
    padding: 1rem;
  }

  h3 {
    color: var(--text);
    font-size: 1.25rem;
    margin-bottom: 0.5rem;
  }

  .description {
    color: var(--text-muted);
    font-size: 0.875rem;
    margin-bottom: 0.75rem;
    line-height: 1.4;
  }

  .dev-period {
    font-size: 0.75rem;
    color: var(--text-muted);
    margin-bottom: 0.75rem;
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  .tech-stack {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
</style>
